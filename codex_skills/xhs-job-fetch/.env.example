# Optional overrides for xhs-job-fetch skill.
# Copy to .env.local in this folder and fill values.

# Workflow repository root. Default: auto-detected repo root.
WORKFLOW_DIR=/path/to/xiaohongshu_workflow

# Local MCP binary path (recommended). Alternative: keep empty and ensure
# `xiaohongshu-mcp` is available in PATH.
XHS_MCP_BINARY_PATH=/abs/path/to/xiaohongshu-mcp

# Default MCP source repo for auto-install.
XHS_MCP_REPO_URL=https://github.com/xpzouying/xiaohongshu-mcp

# 建议显式传入抓取需求（避免默认值误跑）
JOB_TOPIC=AI 工具
JOB_REGION=上海
JOB_TIME_CONSTRAINT=近7天
JOB_OUTPUT_FORMAT=both

# 默认开启需求校验：缺少主题/时间约束/返回格式会阻断执行
XHS_REQUIREMENT_GUARD=1

# Optional Feishu bot webhook override.
# Keep secrets in .env.local only; do not commit real values.
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/replace-me
FEISHU_WEBHOOK_TIMEOUT=15

# Optional: enables "send QR image to Feishu + auto continue after scan".
# If omitted, workflow falls back to "text-only notify + manual local login".
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# Auto-login behavior
XHS_AUTO_LOGIN_FEISHU=1
XHS_LOGIN_WAIT_SECONDS=420
XHS_LOGIN_POLL_SECONDS=25
XHS_LOGIN_QR_REFRESH_SECONDS=210
# Reset cookies before generating QR to avoid stale-session login failures.
XHS_RESET_COOKIES_BEFORE_QR=0
XHS_ENFORCE_HEADLESS_TRUE=1

# MCP launch mode. Keep true to avoid visible browser login windows.
XHS_MCP_HEADLESS=true
